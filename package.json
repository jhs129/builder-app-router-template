{
  "name": "@jhs129/builder-app-router-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build": "turbo run build --filter=!storybook-app",
    "build-all": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "dev:app-0": "turbo run dev --filter=app-0",
    "dev:storybook": "turbo run storybook --filter=storybook-app",
    "build:app-0": "turbo run build --filter=app-0",
    "build:storybook": "turbo run build-storybook --filter=storybook-app"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5"
  }
}
