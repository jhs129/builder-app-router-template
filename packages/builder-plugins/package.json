{
  "name": "builder-plugins",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build:tailwind": "postcss src/styles.css -o dist/tailwind.css",
    "build:js": "tsup src/index.tsx --format esm,cjs --dts --external react --external next --splitting false",
    "build:css": "cp dist/tailwind.css dist/index.css",
    "build": "pnpm run build:tailwind && pnpm run build:js && pnpm run build:css",
    "dev": "tsup src/index.tsx --format esm,cjs --watch --dts --external react --external next --splitting false",
    "lint": "eslint \"src/**/*.ts*\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@swc/core": "^1.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.1",
    "next": "^16.0.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.1",
    "react": "^19.0.0",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0"
  },
  "dependencies": {
    "@builder.io/react": "^8.0.0",
    "@builder.io/sdk": "^6.0.5",
    "@tabler/icons-react": "^3.0.0",
    "algoliasearch": "^5.23.4",
    "instantsearch.js": "^4.0.0",
    "react-instantsearch": "^7.0.0"
  }
}
