# ---------------------------------------------------------------------------
# app-0 environment variables
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. Everything
# else is server-only and must never be committed.
# ---------------------------------------------------------------------------

# --- Builder.io (required) -------------------------------------------------

# Public API key for your Builder.io space. Used to fetch page, article, and
# site-context content. Find it under Account Settings in the Builder editor.
NEXT_PUBLIC_BUILDER_API_KEY=

# Private API key, used ONLY by the seed script (`scripts/seed-builder.mjs`)
# to create models/content via the Builder Admin API. Not needed at runtime.
BUILDER_PRIVATE_KEY=

# Name of the `site-context` entry to load (siteName, logo, organization,
# contact, navigation, social links). Defaults to "builder-app-template".
NEXT_PUBLIC_SITE_CONTEXT_NAME=builder-app-template

# --- Site URL (recommended) ------------------------------------------------

# Canonical, fully-qualified site origin (no trailing slash), e.g.
# https://www.example.com. Used for metadata canonical/OG URLs, JSON-LD
# schema @id/url values, and the sitemap. When unset, schema @id/url values
# fall back to bare fragments and the sitemap falls back to NEXT_PUBLIC_VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Auto-populated by Vercel with the deployment's host (no protocol). Used as a
# sitemap fallback when NEXT_PUBLIC_SITE_URL is not set. Leave blank locally.
NEXT_PUBLIC_VERCEL_URL=

# --- Optional -------------------------------------------------------------

# Default placeholder image shown for components in the Builder insert menu.
# When unset, components register without a preview image.
NEXT_DEFAULT_COMPONENT_IMAGE=

# Comma-separated list of URL paths to exclude from the generated sitemap,
# e.g. "/404,/section-editors". Whitespace around entries is trimmed.
SITEMAP_EXCLUDED_PATHS=

# Vercel Protection Bypass token. When set, the proxy forwards it as the
# `x-vercel-protection-bypass` header so locale redirects can reach
# password/deployment-protected preview environments.
VERCEL_PROTECTION_BYPASS=
